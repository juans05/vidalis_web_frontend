# API Gateway
API_GATEWAY_PORT=3000
NODE_ENV=development

# Auth Service
AUTH_SERVICE_PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRES_IN=7d

# Content Service
CONTENT_SERVICE_PORT=3002

# Analytics Service
ANALYTICS_SERVICE_PORT=3003

# Growth Service
GROWTH_SERVICE_PORT=3004

# Social Service
SOCIAL_SERVICE_PORT=3005

# External APIs
CLOUDINARY_URL=https://api.cloudinary.com
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Redis
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vidalis_db

# Backend existente
EXISTING_BACKEND_URL=https://backend-vidalis-production.up.railway.app

# Logging
LOG_LEVEL=debug
