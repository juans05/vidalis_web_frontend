{
  "name": "vidalis-backend",
  "version": "1.0.0",
  "description": "Vidalis.AI Backend - Microservices Architecture",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "NODE_OPTIONS=--loader=ts-node/esm node --test src/**/*.test.ts"
  },
  "keywords": [
    "vidalis",
    "microservices",
    "express",
    "typescript"
  ],
  "author": "Juan",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.2",
    "bcrypt": "^5.1.1",
    "axios": "^1.6.5",
    "@supabase/supabase-js": "^2.38.0",
    "form-data": "^4.0.0",
    "redis": "^4.6.12",
    "bull": "^4.11.5",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.17",
    "@types/form-data": "^0.0.33",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
